---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} Notes by Wenchao. All rights reserved.</p>
	<p class="links">
		<a href="/rss.xml">RSS</a>
		<span>·</span>
		<a href="https://github.com/suprewen/wc-blog" target="_blank">GitHub</a>
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0.3rem 0;
	}
	.links {
		display: flex;
		justify-content: center;
		gap: 0.5em;
	}
	.links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
