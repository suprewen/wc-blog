---
const repo = import.meta.env.PUBLIC_UTTERANCES_REPO;
---

{repo ? (
	<section class="comments">
		<script
			src="https://utteranc.es/client.js"
			repo={repo}
			issue-term="pathname"
			label="comment"
			theme="github-light"
			crossorigin="anonymous"
			async
		></script>
	</section>
) : (
	<section class="comments comments-disabled">
		<p>Comments are ready. Set <code>PUBLIC_UTTERANCES_REPO=owner/wc-blog</code> after enabling GitHub Issues.</p>
	</section>
)}

<style>
	.comments {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.comments-disabled {
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
</style>
